<!DOCTYPE html>
<html lang="en">
<head>
   <%- include("./partials/head") %>
   <title>Blog page</title>
</head>
<body>
    <%- include("./partials/nav") %>
   <div class="container mt-4">
       <h1 class="mb-4"><%= blog.title %></h1>
       <img src="<%= blog.coverImageUrl %>" class="mb-4" width="800px" alt="">
       <p class="fs-3 " ><%= blog.body %></p>
   </div>
   <div class="container">
    <h2>comment(<%= comments.length %>)</h2>
     <% if (locals.user) { %>
       <form action="/blog/comment/<%= blog._id %>" method="post">
  <div class="mb-3">
    <input type="text" name="content" class="form-control"  placeholder="enter your comment" aria-describedby="emailHelp">
  </div>
  <button class="btn btn-primary">Add</button>
</form>
     <% } %>
     <div class="mt-4">
         <% comments.forEach(comment => { %>
          <div>
          <h6>user :-</h6>
         <pre><%= comment.content %></pre>
          </div>
         <% }) %>
     </div>
   </div>
    <%- include("./partials/scripts") %>
</body>
</html>